# --- База данных ---
POSTGRES_USER=esque
POSTGRES_PASSWORD=esque_dev_password
POSTGRES_DB=esque
# Для локальной разработки без Docker: host=localhost; внутри compose web использует host=db
DATABASE_URL=postgresql://esque:esque_dev_password@localhost:5432/esque

# --- Медиа-хранилище ---
# Локально и в docker compose — MinIO (S3). На Vercel контейнера с MinIO нет,
# там хранилище — Vercel Blob: платформа сама подставляет BLOB_READ_WRITE_TOKEN,
# и src/lib/storage.ts по его наличию переключает движок. Локально токена нет.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=esque_minio
S3_SECRET_KEY=esque_minio_secret
S3_BUCKET=media
# Публичный URL, по которому браузер получает картинки из бакета
S3_PUBLIC_URL=http://localhost:9000/media
# Только на Vercel (обычно подставляется автоматически при создании Blob-хранилища):
# BLOB_READ_WRITE_TOKEN=
# Адрес Blob выводится из токена; задавайте, только если хранилище нестандартное:
# BLOB_PUBLIC_URL=

# --- Сайт ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# 1 на демо-стенде: закрывает сайт от индексации целиком (тексты дублируют живой
# esque.su — индексация копии бьёт по позициям оригинала). На проде НЕ ставить.
NEXT_PUBLIC_IS_DEMO=

# --- Аутентификация админки ---
AUTH_SECRET=replace_with_long_random_string

# --- Демо-стенд (Vercel + Neon + Vercel Blob) ---
# Нужны только для `npm run export-demo` — перелива выборки материалов на демо.
# На самом Vercel они не нужны: там задаются DATABASE_URL и BLOB_READ_WRITE_TOKEN.
DEMO_DATABASE_URL=
DEMO_BLOB_TOKEN=
DEMO_ADMIN_PASSWORD=
